---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allWriting = await getCollection('writing');
const sorted = allWriting.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title="Writing — Leslie Baynes"
  description="Essays, articles, and shorter writing by Leslie Baynes for general and academic audiences."
  activePage="writing"
>

  <section class="writing-hero">
    <div class="section-label">Writing</div>
    <h1>Essays and articles</h1>
    <p class="lede">
      A selection of shorter pieces for general and academic readers. For a complete list of
      academic publications, see the full CV.
    </p>
  </section>

  <section class="writing-list">
    {sorted.length === 0 ? (
      <p class="empty">Entries coming soon.</p>
    ) : (
      <ul>
        {sorted.map(piece => (
          <li>
            <div class="piece-date">
              {piece.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            </div>
            <div class="piece-body">
              <h3>
                {piece.data.url ? (
                  <a href={piece.data.url} target="_blank" rel="noopener">
                    {piece.data.title}
                  </a>
                ) : piece.data.title}
              </h3>
              <p class="piece-publication"><em>{piece.data.publication}</em></p>
              {piece.data.summary && <p class="piece-summary">{piece.data.summary}</p>}
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="cv-cta">
    <div class="cv-cta-inner">
      <div>
        <h3>Full publication list</h3>
        <p>Complete academic bibliography available in the CV.</p>
      </div>
      <a href="/cv-leslie-baynes.pdf" class="btn">Download CV</a>
    </div>
  </section>

</Base>

<style>
  .writing-hero {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 48px 60px;
    text-align: center;
  }

  @media (max-width: 900px) { .writing-hero { padding: 48px 24px 40px; } }

  .writing-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(44px, 5vw, 68px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    line-height: 1.1;
    color: var(--ink);
    margin-top: 24px;
    margin-bottom: 28px;
  }

  .writing-hero .lede {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 300;
    font-variation-settings: "opsz" 60;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .writing-list {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 48px 80px;
  }

  @media (max-width: 900px) { .writing-list { padding: 40px 24px 60px; } }

  .writing-list .empty {
    font-family: var(--font-body);
    color: var(--ink-muted);
    font-style: italic;
    text-align: center;
    padding: 40px 0;
  }

  .writing-list ul {
    list-style: none;
  }

  .writing-list li {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 48px;
    padding: 32px 0;
    border-bottom: 1px solid var(--rule);
  }

  .writing-list li:first-child { border-top: 1px solid var(--rule); }

  @media (max-width: 720px) {
    .writing-list li {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .piece-date {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sepia);
    padding-top: 4px;
  }

  .piece-body h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .piece-body h3 a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dotted var(--oxblood);
    transition: color 0.2s ease;
  }

  .piece-body h3 a:hover { color: var(--oxblood); }

  .piece-publication {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--ink-muted);
    margin-bottom: 12px;
  }

  .piece-summary {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .cv-cta {
    background: var(--ivory-deep);
    padding: 60px 48px;
  }

  @media (max-width: 900px) { .cv-cta { padding: 48px 24px; } }

  .cv-cta-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cv-cta h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .cv-cta p {
    font-family: var(--font-body);
    color: var(--ink-muted);
    font-size: 15px;
  }
</style>
