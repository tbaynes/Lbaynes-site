---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Pull top 8 podcast appearances, most recent first
const allPodcasts = await getCollection('podcasts');
const recentPodcasts = allPodcasts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);

// Pull the lead endorsement
const allEndorsements = await getCollection('endorsements');
const leadEndorsement = allEndorsements.find(e => e.data.tier === 'lead');
---

<Base title="Leslie Baynes — Biblical Scholar" activePage="home">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-text">
      <div class="eyebrow animate-rise" style="animation-delay: 0.05s;">
        Biblical Scholar · Author · Translator
      </div>
      <h1 class="animate-rise" style="animation-delay: 0.15s;">
        Reading Scripture, reading Lewis.
      </h1>
      <p class="lede animate-rise" style="animation-delay: 0.3s;">
        Leslie Baynes is a scholar of the New Testament and Second Temple Judaism whose work ranges
        from ancient apocalyptic literature to the Christian imagination of the twentieth century &mdash;
        from 1 Enoch to Narnia, often in the same week.
      </p>
      <p class="credential animate-rise" style="animation-delay: 0.45s;">
        Professor of Religious Studies at Missouri State University. Translator of the New American
        Bible Revised Edition, approved for Catholic liturgical use in June 2025.
      </p>
    </div>

    <div class="hero-image animate-fade" style="animation-delay: 0.2s;">
      <img
        src="/images/headshot-hero.jpg"
        alt="Portrait of Leslie Baynes"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <div class="section-divider">
    <span class="ornament">&#9753;</span>
  </div>

  <!-- BOOK FEATURE -->
  <section class="book-feature">
    <a href="/book" class="book-cover-real">
      <img
        src="/images/book-cover-medium.jpg"
        alt="Between Interpretation and Imagination: C. S. Lewis and the Bible"
        loading="lazy"
      />
    </a>

    <div class="book-text">
      <div class="section-label">New &mdash; Eerdmans, 2025</div>
      <h2>Between Interpretation &amp; Imagination</h2>
      <p class="book-subtitle">C. S. Lewis and the Bible</p>
      <p class="desc">
        Drawing on never-before-published marginalia from Lewis&rsquo;s personal library, alongside
        his letters, essays, and fiction, <em>Between Interpretation and Imagination</em> is the
        first full-length study of Lewis&rsquo;s engagement with Scripture &mdash; and the first to
        treat him with the scholarly seriousness he both demanded and deserved.
      </p>

      {leadEndorsement && (
        <div class="endorsement-preview">
          <blockquote>
            &ldquo;A first-rate study that, by turns, chides, challenges, and champions
            Lewis&rsquo;s various approaches to the Bible. Scholarly and spirited, this is easily
            the best book yet written on Lewis and Scripture.&rdquo;
          </blockquote>
          <cite>
            <strong>Michael Ward</strong> &mdash; University of Oxford
          </cite>
        </div>
      )}

      <div class="purchase-buttons">
        <a href="/book" class="btn primary">Read More</a>
        <a href="#" class="btn">Bookshop.org</a>
        <a href="#" class="btn">Eerdmans</a>
      </div>
    </div>
  </section>

  <!-- RECENT APPEARANCES -->
  <section class="appearances">
    <div class="section-label">Recently On</div>
    <h3>In conversation</h3>
    <div class="podcast-grid">
      {recentPodcasts.map((podcast, i) => (
        <span class="podcast-item">
          {podcast.data.title}
        </span>
      ))}
    </div>
    <a href="/media" class="see-all">See all appearances &rarr;</a>
  </section>

  <!-- THREE PATHS -->
  <section class="paths">
    <a href="/book" class="path-card">
      <div class="path-number">I.</div>
      <h4>For Readers</h4>
      <p>Learn about the book, read excerpts, and find it at your bookseller of choice.</p>
      <span class="path-link">The Book</span>
    </a>
    <a href="/media" class="path-card">
      <div class="path-number">II.</div>
      <h4>For Event Organizers</h4>
      <p>Topics, press kit, past appearances, and booking information for podcasts, keynotes, and panels.</p>
      <span class="path-link">Media &amp; Speaking</span>
    </a>
    <a href="/about" class="path-card">
      <div class="path-number">III.</div>
      <h4>For Scholars</h4>
      <p>Academic publications, research interests, teaching, and a downloadable CV.</p>
      <span class="path-link">About &amp; CV</span>
    </a>
  </section>

</Base>

<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 48px 120px;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 80px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 60px 24px 80px;
      gap: 48px;
    }
  }

  .hero-text .eyebrow {
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .hero-text .eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--oxblood);
  }

  .hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(54px, 7vw, 92px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 36px;
  }

  .hero-text .lede {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 300;
    font-variation-settings: "opsz" 60;
    line-height: 1.45;
    color: var(--ink-soft);
    max-width: 540px;
    margin-bottom: 20px;
  }

  .hero-text .credential {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-muted);
    max-width: 520px;
  }

  .hero-image {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 2px;
    box-shadow:
      0 2px 4px rgba(35, 28, 21, 0.04),
      0 20px 40px rgba(35, 28, 21, 0.12),
      0 40px 80px rgba(35, 28, 21, 0.08);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
  }

  .hero-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(107, 40, 36, 0.06) 100%);
    pointer-events: none;
  }

  /* BOOK FEATURE */
  .book-feature {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 120px 48px;
    display: grid;
    grid-template-columns: 0.75fr 1fr;
    gap: 100px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .book-feature {
      grid-template-columns: 1fr;
      padding: 80px 24px;
      gap: 60px;
    }
  }

  .book-cover-real {
    position: relative;
    aspect-ratio: 1838/2775;
    box-shadow:
      -2px 2px 0 #d8cdb5,
      0 2px 4px rgba(35, 28, 21, 0.08),
      0 30px 60px rgba(35, 28, 21, 0.18),
      0 60px 120px rgba(35, 28, 21, 0.1);
    overflow: hidden;
    border-radius: 1px;
    transform: rotate(-1.2deg);
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    display: block;
    text-decoration: none;
  }

  .book-cover-real:hover {
    transform: rotate(0deg) translateY(-4px);
  }

  .book-cover-real::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 8px;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.25), transparent);
    z-index: 2;
    pointer-events: none;
  }

  .book-text h2 {
    font-family: var(--font-display);
    font-size: clamp(38px, 4.6vw, 60px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .book-text .book-subtitle {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 26px);
    font-weight: 300;
    font-style: italic;
    color: var(--ink-muted);
    margin-bottom: 36px;
  }

  .book-text .desc {
    font-size: 19px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin-bottom: 20px;
    max-width: 560px;
  }

  .endorsement-preview {
    border-left: 2px solid var(--oxblood);
    padding: 8px 0 8px 28px;
    margin: 40px 0;
    max-width: 560px;
  }

  .endorsement-preview blockquote {
    font-family: var(--font-display);
    font-size: clamp(19px, 2vw, 23px);
    font-weight: 300;
    font-style: italic;
    line-height: 1.45;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .endorsement-preview cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 14px;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  .endorsement-preview cite strong {
    color: var(--ink);
    font-weight: 600;
  }

  .purchase-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  /* APPEARANCES */
  .appearances {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 100px 48px;
    text-align: center;
  }

  @media (max-width: 900px) {
    .appearances { padding: 60px 24px; }
  }

  .appearances h3 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.6vw, 44px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    margin-top: 16px;
    margin-bottom: 56px;
  }

  .podcast-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    margin-bottom: 40px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .podcast-item {
    padding: 14px 24px;
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    position: relative;
  }

  .podcast-item:not(:last-child)::after {
    content: '·';
    position: absolute;
    right: -4px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--sepia);
    font-size: 20px;
  }

  .see-all {
    font-family: var(--font-body);
    color: var(--oxblood);
    font-size: 16px;
    text-decoration: none;
    border-bottom: 1px solid var(--oxblood);
    padding-bottom: 2px;
  }

  /* PATHS */
  .paths {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 48px 120px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  @media (max-width: 900px) {
    .paths {
      grid-template-columns: 1fr;
      padding: 40px 24px 60px;
    }
  }

  .path-card {
    background: var(--ivory);
    padding: 56px 40px;
    text-align: left;
    transition: background 0.3s ease;
    text-decoration: none;
  }

  .path-card:hover { background: var(--cream); }

  .path-number {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--sepia);
    margin-bottom: 24px;
    letter-spacing: 0.08em;
  }

  .path-card h4 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    color: var(--ink);
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .path-card p {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 24px;
  }

  .path-link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--oxblood);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.3s ease;
  }

  .path-card:hover .path-link { gap: 14px; }
  .path-link::after { content: '→'; font-family: var(--font-display); }
</style>
