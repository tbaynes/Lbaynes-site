---
import Base from '../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

const page = await getEntry('pages', 'book');
if (!page || page.data.page !== 'book') {
  throw new Error('Missing book page content entry (src/content/pages/book.md)');
}
const data = page.data;

const allEndorsements = await getCollection('endorsements');
const sorted = allEndorsements.sort((a, b) => a.data.order - b.data.order);

const leadQuote = sorted.find(e => e.data.tier === 'lead');
const featured = sorted.filter(e => e.data.tier === 'featured');
const supporting = sorted.filter(e => e.data.tier === 'supporting');
const reviews = sorted.filter(e => e.data.tier === 'review');
---

<Base
  title={data.pageTitle}
  description={data.pageDescription}
  activePage="book"
>

  <!-- HERO -->
  <section class="book-hero">
    <div class="book-cover-real">
      <img
        src={data.coverImage}
        alt={data.coverAlt}
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <div class="book-hero-text">
      <div class="meta">{data.meta}</div>
      <h1>{data.bookTitle}</h1>
      <p class="subtitle">{data.bookSubtitle}</p>

      <p class="question" set:html={data.question}></p>

      <p class="desc" set:html={data.description}></p>

      <div class="purchase-buttons">
        {data.buyLinks.map(b => (
          <a href={b.url} class={b.primary ? "btn primary" : "btn"}>{b.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- PRAISE -->
  <section class="praise-section">
    <div class="praise-inner">
      <div class="praise-header">
        <div class="section-label">{data.praiseEyebrow}</div>
        <h2>{data.praiseHeading}</h2>
      </div>

      {leadQuote && (
        <div class="lead-quote">
          <blockquote set:html={leadQuote.body.replace(/^"|"$/g, '')}></blockquote>
          <cite>
            <strong>{leadQuote.data.author}</strong>
            {leadQuote.data.affiliation}
            {leadQuote.data.bookTitle && (
              <> &middot; author of <em>{leadQuote.data.bookTitle}</em></>
            )}
          </cite>
        </div>
      )}

      {featured.length > 0 && (
        <div class="praise-tier-2">
          {featured.map(e => (
            <div class="praise-item">
              <blockquote>&ldquo;<span set:html={e.body.replace(/^"|"$/g, '')} />&rdquo;</blockquote>
              <cite>
                <strong>{e.data.author}</strong>
                {e.data.affiliation}
                {e.data.bookTitle && (
                  <> &middot; author of <em>{e.data.bookTitle}</em></>
                )}
              </cite>
            </div>
          ))}
        </div>
      )}

      {supporting.length > 0 && (
        <div class="praise-tier-3">
          {supporting.map(e => (
            <div class="praise-small">
              <blockquote>&ldquo;<span set:html={e.body.replace(/^"|"$/g, '')} />&rdquo;</blockquote>
              <cite><strong>{e.data.author}</strong>{e.data.affiliation}</cite>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ABOUT THE BOOK -->
  <section class="about-book">
    <div class="section-label">{data.aboutBookEyebrow}</div>
    <h2>{data.aboutBookHeading}</h2>

    {data.aboutBookParagraphs.map(p => (
      <p class={p.accent ? "accent-line" : undefined} set:html={p.text}></p>
    ))}
  </section>

  <!-- CONTENTS -->
  <section class="contents">
    <div class="contents-inner">
      <div class="section-label">{data.contentsEyebrow}</div>
      <h2 set:html={data.contentsHeading}></h2>

      {data.contentsParts.map(part => (
        <div class="contents-part">
          <h3>{part.label}</h3>
          <p class="subtitle" set:html={part.subtitle}></p>
          <ul>
            {part.chapters.map(ch => (
              <li set:html={ch}></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- AUTHOR -->
  <section class="author-block">
    <div class="author-image">
      <img
        src={data.authorImage}
        alt={data.authorImageAlt}
        loading="lazy"
      />
    </div>
    <div class="author-text">
      <div class="section-label">{data.authorEyebrow}</div>
      <h2>{data.authorName}</h2>
      {data.authorParagraphs.map(para => (
        <p set:html={para}></p>
      ))}
      <a href={data.authorLinkHref} class="link" set:html={data.authorLinkLabel}></a>
    </div>
  </section>

</Base>

<style>
  /* BOOK HERO */
  .book-hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 48px 100px;
    display: grid;
    grid-template-columns: 0.75fr 1fr;
    gap: 100px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .book-hero {
      grid-template-columns: 1fr;
      padding: 48px 24px 60px;
      gap: 48px;
    }
  }

  .book-cover-real {
    position: relative;
    aspect-ratio: 1838/2775;
    box-shadow:
      -3px 3px 0 #d8cdb5,
      0 4px 6px rgba(35, 28, 21, 0.08),
      0 40px 80px rgba(35, 28, 21, 0.22),
      0 80px 140px rgba(35, 28, 21, 0.1);
    overflow: hidden;
    border-radius: 1px;
    position: sticky;
    top: 40px;
  }

  .book-cover-real::before {
    content: '';
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 10px;
    background: linear-gradient(to right, rgba(0,0,0,0.2), transparent);
    z-index: 2;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .book-cover-real {
      position: static;
      max-width: 360px;
      margin: 0 auto;
    }
  }

  .book-hero-text .meta {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--sepia);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .book-hero-text .meta::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--sepia);
  }

  .book-hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 84px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 40, "WONK" 1;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .book-hero-text .subtitle {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.6vw, 32px);
    font-weight: 300;
    font-style: italic;
    color: var(--ink-muted);
    margin-bottom: 40px;
  }

  .book-hero-text .question {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.2vw, 28px);
    font-weight: 400;
    line-height: 1.35;
    color: var(--ink);
    margin-bottom: 28px;
    max-width: 620px;
  }

  .book-hero-text .desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 580px;
    margin-bottom: 20px;
  }

  .purchase-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 44px;
  }

  /* PRAISE */
  .praise-section {
    background: var(--cream);
    padding: 120px 48px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  @media (max-width: 900px) {
    .praise-section { padding: 80px 24px; }
  }

  .praise-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .praise-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .praise-header h2 {
    font-family: var(--font-display);
    font-size: clamp(38px, 4.4vw, 58px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin-top: 16px;
  }

  .lead-quote {
    max-width: 900px;
    margin: 0 auto 100px;
    text-align: center;
    position: relative;
  }

  .lead-quote::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 180px;
    color: var(--oxblood);
    opacity: 0.12;
    position: absolute;
    top: -40px;
    left: -20px;
    line-height: 1;
  }

  .lead-quote blockquote {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.2vw, 40px);
    font-weight: 300;
    font-variation-settings: "opsz" 60;
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: 36px;
    letter-spacing: -0.005em;
    position: relative;
  }

  .lead-quote cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 15px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .lead-quote cite strong {
    color: var(--ink);
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
    letter-spacing: 0.14em;
  }

  .praise-tier-2 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
    margin-bottom: 100px;
    padding-top: 80px;
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 900px) {
    .praise-tier-2 { grid-template-columns: 1fr; gap: 60px; }
  }

  .praise-item blockquote {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 400;
    font-variation-settings: "opsz" 60;
    line-height: 1.55;
    color: var(--ink);
    margin-bottom: 20px;
    font-style: italic;
  }

  .praise-item cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    line-height: 1.5;
    display: block;
  }

  .praise-item cite strong {
    color: var(--ink);
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
    font-size: 14px;
    letter-spacing: 0.12em;
  }

  .praise-tier-3 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px;
    padding-top: 80px;
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 720px) {
    .praise-tier-3 { grid-template-columns: 1fr; }
  }

  .praise-small blockquote {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    font-style: italic;
    margin-bottom: 14px;
  }

  .praise-small cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: block;
  }

  .praise-small cite strong {
    color: var(--ink);
    font-weight: 600;
    display: block;
    margin-bottom: 2px;
    font-size: 13px;
    letter-spacing: 0.12em;
  }

  /* ABOUT BOOK */
  .about-book {
    max-width: 800px;
    margin: 0 auto;
    padding: 120px 48px;
  }

  @media (max-width: 900px) {
    .about-book { padding: 80px 24px; }
  }

  .about-book .section-label {
    text-align: center;
    display: block;
    margin-bottom: 20px;
  }

  .about-book h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.4vw, 56px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    color: var(--ink);
    text-align: center;
    margin-bottom: 64px;
    letter-spacing: -0.01em;
  }

  .about-book p {
    font-family: var(--font-body);
    font-size: 19px;
    line-height: 1.75;
    color: var(--ink-soft);
    margin-bottom: 28px;
  }

  .about-book p:first-of-type::first-letter {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    float: left;
    line-height: 0.85;
    padding-top: 6px;
    padding-right: 12px;
    padding-bottom: 0;
    color: var(--oxblood-deep);
  }

  .about-book .accent-line {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    text-align: center;
    padding: 40px 0;
    max-width: 600px;
    margin: 40px auto;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  /* CONTENTS */
  .contents {
    background: var(--ivory-deep);
    padding: 100px 48px;
  }

  @media (max-width: 900px) {
    .contents { padding: 60px 24px; }
  }

  .contents-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .contents .section-label {
    text-align: center;
    display: block;
    margin-bottom: 20px;
  }

  .contents h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.6vw, 44px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    text-align: center;
    margin-bottom: 56px;
  }

  .contents-part {
    margin-bottom: 56px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--rule);
  }

  .contents-part:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .contents-part h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .contents-part .subtitle {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: 18px;
    margin-bottom: 28px;
  }

  .contents-part ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px 40px;
  }

  @media (max-width: 720px) {
    .contents-part ul { grid-template-columns: 1fr; }
  }

  .contents-part li {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-soft);
    padding-left: 28px;
    position: relative;
  }

  .contents-part li::before {
    content: counter(chapters, upper-roman) '.';
    counter-increment: chapters;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--sepia);
    position: absolute;
    left: 0;
    font-size: 14px;
  }

  .contents-part ul {
    counter-reset: chapters;
  }

  /* AUTHOR BLOCK */
  .author-block {
    max-width: 1100px;
    margin: 0 auto;
    padding: 120px 48px;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .author-block {
      grid-template-columns: 1fr;
      padding: 80px 24px;
      gap: 48px;
    }
  }

  .author-image {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 2px;
    box-shadow: 0 20px 40px rgba(35, 28, 21, 0.1);
  }

  .author-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
  }

  .author-text h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.6vw, 46px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    margin-top: 16px;
    margin-bottom: 28px;
    line-height: 1.1;
  }

  .author-text p {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-bottom: 20px;
  }

  .author-text .link {
    font-family: var(--font-body);
    color: var(--oxblood);
    text-decoration: none;
    font-size: 16px;
    border-bottom: 1px solid var(--oxblood);
    padding-bottom: 2px;
    display: inline-block;
    margin-top: 12px;
  }
</style>
