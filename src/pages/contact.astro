---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
if (!page || page.data.page !== 'contact') {
  throw new Error('Missing contact page content entry (src/content/pages/contact.md)');
}
const data = page.data;
---

<Base
  title={data.pageTitle}
  description={data.pageDescription}
  activePage="contact"
>

  <section class="contact-hero">
    <div class="section-label">{data.sectionLabel}</div>
    <h1>{data.heading}</h1>
    <p class="lede">{data.lede}</p>
  </section>

  <section class="contact-options">
    {data.contactCards.map(card => (
      <div class="contact-card">
        <div class="contact-icon">{card.icon}</div>
        <h3 set:html={card.heading}></h3>
        <p>{card.body}</p>
        <a href={`mailto:${card.email}`} class="contact-email">{card.email}</a>
        <p class="response-time" set:html={card.responseTime}></p>
      </div>
    ))}
  </section>

  <section class="affiliation">
    <h3>{data.affiliationHeading}</h3>
    <p>
      {data.affiliationLines.map((line, i) => (
        <Fragment>
          {line}{i < data.affiliationLines.length - 1 && <br />}
        </Fragment>
      ))}
    </p>
    {data.affiliationEmail && (
      <p class="mu-email">
        <a href={`mailto:${data.affiliationEmail}`}>{data.affiliationEmail}</a>
      </p>
    )}
  </section>

</Base>

<style>
  .contact-hero {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 48px 40px;
    text-align: center;
  }

  @media (max-width: 900px) { .contact-hero { padding: 48px 24px 32px; } }

  .contact-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(44px, 5vw, 68px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    line-height: 1.1;
    color: var(--ink);
    margin-top: 24px;
    margin-bottom: 28px;
  }

  .contact-hero .lede {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 300;
    font-variation-settings: "opsz" 60;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .contact-options {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 48px 80px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  @media (max-width: 900px) {
    .contact-options {
      grid-template-columns: 1fr;
      padding: 40px 24px 60px;
      gap: 32px;
    }
  }

  .contact-card {
    background: var(--cream);
    padding: 40px 32px;
    border-radius: 2px;
    border: 1px solid var(--rule);
    text-align: center;
  }

  .contact-icon {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    color: var(--oxblood);
    width: 64px;
    height: 64px;
    line-height: 64px;
    margin: 0 auto 20px;
    border: 1px solid var(--oxblood);
    border-radius: 50%;
  }

  .contact-card h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .contact-card p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 20px;
  }

  .contact-email {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--oxblood);
    text-decoration: none;
    border-bottom: 1px solid var(--oxblood);
    padding-bottom: 2px;
    display: inline-block;
    margin-bottom: 16px;
    word-break: break-all;
  }

  .contact-email:hover { color: var(--oxblood-deep); border-color: var(--oxblood-deep); }

  .response-time {
    font-size: 13px !important;
    color: var(--sepia) !important;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0 !important;
  }

  .affiliation {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 48px;
    text-align: center;
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 900px) { .affiliation { padding: 60px 24px; } }

  .affiliation h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 28px;
  }

  .affiliation p {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.8;
    color: var(--ink-soft);
    margin-bottom: 20px;
  }

  .mu-email a {
    color: var(--oxblood);
    text-decoration: none;
    border-bottom: 1px solid var(--oxblood);
    padding-bottom: 2px;
  }
</style>
