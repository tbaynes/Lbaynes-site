---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPodcasts = await getCollection('podcasts');
const sorted = allPodcasts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const upcoming = sorted.filter(p => p.data.upcoming);
const past = sorted.filter(p => !p.data.upcoming);
---

<Base
  title="Media & Speaking — Leslie Baynes"
  description="Press kit, podcast appearances, keynote topics, and booking information for Leslie Baynes."
  activePage="media"
>

  <section class="speaking-hero">
    <div class="section-label">Media &amp; Speaking</div>
    <h1>Available for interviews, keynotes, and panels</h1>
    <p class="lede">
      Leslie Baynes is available for podcast interviews, keynotes, academic panels, webinars, book
      clubs, and church and parish events &mdash; in person and online.
    </p>
    <div class="cta-row">
      <a href="/contact" class="btn primary">Inquire about booking</a>
      <a href="/press-kit.pdf" class="btn">Download press kit (PDF)</a>
    </div>
  </section>

  <section class="topics">
    <h2>Topics</h2>
    <p class="topics-intro">
      Leslie speaks on three overlapping areas. Hosts are welcome to choose a published topic or
      propose something new; she&rsquo;s comfortable going off-script if the conversation calls
      for it.
    </p>

    <div class="topic-group">
      <h3>C. S. Lewis and the Bible</h3>
      <ul>
        <li>How Lewis actually read Scripture &mdash; and why it matters</li>
        <li>The marginalia in Lewis&rsquo;s personal library: what the notes reveal</li>
        <li>Lewis on the Gospel of John, and why he got it wrong</li>
        <li>The &ldquo;Liar, Lunatic, Lord&rdquo; argument, revisited</li>
        <li>Myth as fact or fiction: Lewis vs. Bultmann</li>
        <li>Lewis and universalism: a reading of <em>The Great Divorce</em></li>
        <li>Scripture hidden in plain sight in the Chronicles of Narnia</li>
        <li>Lewis on biblical inerrancy &mdash; a position neither side expected</li>
      </ul>
    </div>

    <div class="topic-group">
      <h3>Biblical Studies for General Audiences</h3>
      <ul>
        <li>Translating the New American Bible: what the work is like, and why translation choices matter</li>
        <li>The Book of Revelation: what it is, what it isn&rsquo;t, and how to read it</li>
        <li>Apocalyptic literature in the ancient Jewish and Christian world</li>
        <li>1 Enoch and the New Testament</li>
        <li>Heavenly books and divine writing in antiquity</li>
      </ul>
    </div>

    <div class="topic-group">
      <h3>The Life of a Working Scholar</h3>
      <ul>
        <li>Teaching biblical studies in a state university today</li>
        <li>Study-away courses in England and Italy</li>
        <li>What serious biblical scholarship can offer the church &mdash; and what it can&rsquo;t</li>
      </ul>
    </div>
  </section>

  {upcoming.length > 0 && (
    <section class="appearances-section">
      <div class="section-label">Upcoming</div>
      <h2>Forthcoming appearances</h2>
      <ul class="appearance-list">
        {upcoming.map(p => (
          <li>
            <span class="appearance-title">
              {p.data.url ? (
                <a href={p.data.url} target="_blank" rel="noopener">{p.data.title}</a>
              ) : p.data.title}
            </span>
            {p.data.host && <span class="appearance-host">with {p.data.host}</span>}
            {p.data.topic && <span class="appearance-topic">{p.data.topic}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="appearances-section alt">
    <div class="section-label">Recent</div>
    <h2>Recent appearances</h2>
    <ul class="appearance-list">
      {past.map(p => (
        <li>
          <span class="appearance-title">
            {p.data.url ? (
              <a href={p.data.url} target="_blank" rel="noopener">{p.data.title}</a>
            ) : p.data.title}
          </span>
          {p.data.host && <span class="appearance-host">with {p.data.host}</span>}
          {p.data.topic && <span class="appearance-topic">{p.data.topic}</span>}
          <span class="appearance-date">
            {p.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
          </span>
        </li>
      ))}
    </ul>
  </section>

  <section class="formats">
    <h2>Formats</h2>
    <div class="format-grid">
      <div class="format-card">
        <h4>Podcast interview</h4>
        <p>Remote. Standard author interview or deep-dive conversation.</p>
      </div>
      <div class="format-card">
        <h4>Keynote or public lecture</h4>
        <p>30&ndash;60 minutes plus Q&amp;A. In-person or virtual. Universities, seminaries, conferences, Lewis societies, Inklings societies, literary festivals.</p>
      </div>
      <div class="format-card">
        <h4>Book club or parish event</h4>
        <p>20-minute talk plus extended Q&amp;A. Virtual preferred for travel efficiency; in-person negotiable.</p>
      </div>
      <div class="format-card">
        <h4>Academic panel</h4>
        <p>Society of Biblical Literature, Catholic Biblical Association, and similar. Contact directly for proposals.</p>
      </div>
      <div class="format-card">
        <h4>Webinar or online course</h4>
        <p>Single session or short series.</p>
      </div>
    </div>
  </section>

  <section class="cta-bottom">
    <h2>Contact for booking</h2>
    <p>For media and speaking inquiries, response within 3&ndash;5 business days.</p>
    <a href="/contact" class="btn primary">Contact Leslie</a>
  </section>

</Base>

<style>
  .speaking-hero {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 48px 100px;
    text-align: center;
  }

  @media (max-width: 900px) {
    .speaking-hero { padding: 48px 24px 60px; }
  }

  .speaking-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 68px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-top: 24px;
    margin-bottom: 32px;
  }

  .speaking-hero .lede {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 300;
    font-variation-settings: "opsz" 60;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 40px;
  }

  .cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .topics {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 48px;
  }

  @media (max-width: 900px) { .topics { padding: 60px 24px; } }

  .topics h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.6vw, 44px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .topics-intro {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-bottom: 56px;
  }

  .topic-group {
    margin-bottom: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--rule);
  }

  .topic-group:last-child {
    border-bottom: none;
  }

  .topic-group h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    color: var(--oxblood-deep);
    margin-bottom: 20px;
  }

  .topic-group ul {
    list-style: none;
  }

  .topic-group li {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    padding: 8px 0 8px 24px;
    position: relative;
  }

  .topic-group li::before {
    content: '—';
    color: var(--sepia);
    position: absolute;
    left: 0;
  }

  .appearances-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 48px;
  }

  .appearances-section.alt {
    background: var(--ivory-deep);
    max-width: none;
    padding: 80px 48px;
  }

  @media (max-width: 900px) {
    .appearances-section, .appearances-section.alt { padding: 60px 24px; }
  }

  .appearances-section.alt > * {
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .appearances-section h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.4vw, 40px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    margin-top: 16px;
    margin-bottom: 40px;
  }

  .appearance-list {
    list-style: none;
  }

  .appearance-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px 24px;
    padding: 20px 0;
    border-top: 1px solid var(--rule);
    font-family: var(--font-body);
  }

  .appearance-list li:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .appearance-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    grid-column: 1;
  }

  .appearance-title a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dotted var(--oxblood);
    transition: color 0.2s ease;
  }

  .appearance-title a:hover { color: var(--oxblood); }

  .appearance-host {
    font-size: 15px;
    color: var(--ink-muted);
    font-style: italic;
    grid-column: 1;
    grid-row: 2;
  }

  .appearance-topic {
    font-size: 15px;
    color: var(--ink-soft);
    grid-column: 1;
    grid-row: 3;
  }

  .appearance-date {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sepia);
    grid-column: 2;
    grid-row: 1;
    align-self: center;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .appearance-list li { grid-template-columns: 1fr; }
    .appearance-date { grid-column: 1; grid-row: 4; }
  }

  .formats {
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 48px;
  }

  @media (max-width: 900px) { .formats { padding: 60px 24px; } }

  .formats h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.4vw, 40px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    margin-bottom: 40px;
  }

  .format-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
  }

  .format-card {
    padding: 24px 28px;
    border-left: 2px solid var(--sepia);
  }

  .format-card h4 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .format-card p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .cta-bottom {
    max-width: 800px;
    margin: 0 auto;
    padding: 100px 48px;
    text-align: center;
  }

  @media (max-width: 900px) { .cta-bottom { padding: 60px 24px; } }

  .cta-bottom h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.6vw, 44px);
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .cta-bottom p {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--ink-soft);
    margin-bottom: 32px;
  }
</style>
