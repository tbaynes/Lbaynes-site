---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'about');
if (!page || page.data.page !== 'about') {
  throw new Error('Missing about page content entry (src/content/pages/about.md)');
}
const data = page.data;
---

<Base
  title={data.pageTitle}
  description={data.pageDescription}
  activePage="about"
>

  <section class="about-hero">
    <div class="about-text">
      <div class="section-label">{data.sectionLabel}</div>
      <h1>{data.heading}</h1>
      <p class="lede">{data.lede}</p>
      {data.introParagraphs.map(para => (
        <p set:html={para}></p>
      ))}
    </div>

    <div class="about-image">
      <img src={data.headshotImage} alt={data.headshotAlt} loading="eager" />
    </div>
  </section>

  <div class="section-divider">
    <span class="ornament">&#9753;</span>
  </div>

  <section class="origin">
    <h2>{data.originHeading}</h2>
    {data.originParagraphs.map(para => (
      <p set:html={para}></p>
    ))}
  </section>

  <section class="service">
    <h2>{data.serviceHeading}</h2>
    {data.serviceParagraphs.map(para => (
      <p set:html={para}></p>
    ))}
  </section>

  <section class="teaching">
    <h2>{data.teachingHeading}</h2>
    {data.teachingParagraphs.map(para => (
      <p set:html={para}></p>
    ))}
  </section>

  <section class="cv-cta">
    <div class="cv-cta-inner">
      <div>
        <h3>{data.cvHeading}</h3>
        <p>{data.cvDescription}</p>
      </div>
      <a href={data.cvButtonHref} class="btn">{data.cvButtonLabel}</a>
    </div>
  </section>

</Base>

<style>
  .about-hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 48px 100px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 80px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .about-hero {
      grid-template-columns: 1fr;
      padding: 48px 24px 60px;
      gap: 48px;
    }
  }

  .about-text h1 {
    font-family: var(--font-display);
    font-size: clamp(44px, 5.5vw, 72px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 40, "WONK" 1;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-top: 24px;
    margin-bottom: 36px;
  }

  .about-text .lede {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 300;
    font-variation-settings: "opsz" 60;
    line-height: 1.45;
    color: var(--ink-soft);
    margin-bottom: 28px;
  }

  .about-text p {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-bottom: 20px;
  }

  .about-image {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 2px;
    box-shadow:
      0 20px 40px rgba(35, 28, 21, 0.12),
      0 40px 80px rgba(35, 28, 21, 0.08);
    position: sticky;
    top: 40px;
  }

  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
  }

  @media (max-width: 900px) {
    .about-image { position: static; }
  }

  .origin, .service, .teaching {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 48px;
  }

  @media (max-width: 900px) {
    .origin, .service, .teaching { padding: 60px 24px; }
  }

  .origin h2, .service h2, .teaching h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.4vw, 40px);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    color: var(--ink);
    margin-bottom: 36px;
    letter-spacing: -0.005em;
  }

  .origin p, .service p, .teaching p {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.75;
    color: var(--ink-soft);
    margin-bottom: 24px;
  }

  .cv-cta {
    background: var(--ivory-deep);
    padding: 80px 48px;
    margin-top: 40px;
  }

  @media (max-width: 900px) {
    .cv-cta { padding: 60px 24px; }
  }

  .cv-cta-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cv-cta h3 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .cv-cta p {
    font-family: var(--font-body);
    color: var(--ink-muted);
    font-size: 16px;
  }
</style>
